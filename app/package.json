{
  "name": "canvas-agent-app",
  "private": true,
  "version": "0.0.1",
  "description": "An AI design agent that perceives and edits a Figma-like vector document, co-editing alongside a human on a shared canvas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moonslicer/coframe.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c magenta,cyan \"npm:server\" \"vite\"",
    "server": "tsx src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "probe": "tsx src/agent/design-probe.ts",
    "compose-eval": "tsx src/agent/compose-eval.ts",
    "session": "tsx src/agent/design-session.ts",
    "smoke": "tsx src/render/svg-build.test-smoke.ts",
    "smoke:raster": "tsx src/render/raster.test-smoke.ts",
    "smoke:fidelity": "tsx src/render/fidelity.test-smoke.ts",
    "smoke:inputs": "tsx src/render/input-flow.test-smoke.ts",
    "smoke:perception": "tsx src/render/perception.test-smoke.ts",
    "smoke:loop": "tsx src/agent/run.test-smoke.ts",
    "smoke:eval": "tsx src/agent/eval.test-smoke.ts",
    "smoke:plan-coerce": "tsx src/agent/plan-coerce.test-smoke.ts",
    "smoke:verify-repro": "tsx src/agent/verify-repro.test-smoke.ts",
    "smoke:tokens": "tsx src/agent/count-tokens.test-smoke.ts",
    "smoke:server": "tsx src/server/server.test-smoke.ts",
    "smoke:tool": "tsx src/server/tool.test-smoke.ts",
    "smoke:tools": "tsx src/shared/tools.test-smoke.ts",
    "smoke:bounds": "tsx src/shared/bounds.test-smoke.ts",
    "smoke:toolmode": "tsx src/client/toolmode.test-smoke.ts",
    "smoke:canvas-math": "tsx src/client/canvas-math.test-smoke.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@resvg/resvg-js": "^2.6.2",
    "dotenv": "^16.6.1",
    "hono": "^4.12.25",
    "lucide-react": "^0.468.0",
    "openai": "^6.44.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
